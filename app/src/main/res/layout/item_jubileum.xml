<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_jubileum_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/item_measurement_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Daysdddd dd dddd" />

    <TextView
        android:id="@+id/item_measurement_equality"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="@+id/item_measurement_definition"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/item_measurement_definition"
        app:layout_constraintVertical_bias="0.0"
        tools:text="1 Day =" />

    <TextView
        android:id="@+id/item_measurement_definition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:gravity="end"
        android:singleLine="true"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/item_measurement_notifications"
        app:layout_constraintStart_toEndOf="@+id/item_measurement_equality"
        app:layout_constraintTop_toBottomOf="@+id/item_measurement_name"
        tools:text="2 thingies" />

    <ImageView
        android:id="@+id/item_measurement_notifications"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:layout_constraintBottom_toBottomOf="@+id/item_measurement_definition"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/item_measurement_definition"
        app:srcCompat="@drawable/ic_notification"
        app:tint="@color/colorAccent"
        app:tintMode="src_in" />
</androidx.constraintlayout.widget.ConstraintLayout>