<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_measurement_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/item_measurement_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Days"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/item_measurement_equality"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="1 Day ="
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_measurement_name"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="32dp"/>

    <TextView
        android:id="@+id/item_measurement_definition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        tools:text="2 thingies"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_measurement_equality"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="end"/>
</androidx.constraintlayout.widget.ConstraintLayout>