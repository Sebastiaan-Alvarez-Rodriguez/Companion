<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialog_notify_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="400dp">

    <TextView
        android:id="@+id/dialog_notify_question"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="32dp"
        android:text="Notify me..."
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <Spinner
        android:id="@+id/dialog_notify_option_spinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="@+id/dialog_notify_question"
        app:layout_constraintStart_toStartOf="@+id/dialog_notify_question"
        app:layout_constraintTop_toBottomOf="@+id/dialog_notify_question" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialog_notify_before_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:minHeight="160dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/dialog_notify_cancel"
        app:layout_constraintEnd_toEndOf="@+id/dialog_notify_option_spinner"
        app:layout_constraintStart_toStartOf="@+id/dialog_notify_option_spinner"
        app:layout_constraintTop_toBottomOf="@+id/dialog_notify_option_spinner">

        <EditText
            android:id="@+id/dialog_notify_before_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ems="3"
            android:gravity="center_horizontal"
            android:inputType="number"
            android:singleLine="true"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="30" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dialog_notify_before_measurement_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/dialog_notify_before_amount_txt1"
            app:layout_constraintStart_toEndOf="@+id/dialog_notify_before_amount"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/dialog_notify_before_amount_txt1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="before"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="@+id/dialog_notify_before_amount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/dialog_notify_before_amount" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/dialog_notify_accept"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="8dp"
        android:background="@android:color/white"
        android:gravity="center_vertical|center_horizontal"
        android:text="Accept"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.84"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/dialog_notify_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical|center_horizontal"
        android:text="Cancel"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.148"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>